# Quanta standalone — Docker environment. Copy to .env and fill in (all optional).
# With no keys it runs in synthetic/mock demo mode so you can try the UI instantly.

# Market data (Polygon powers the bars/signals/charts; Finnhub powers quotes/news/earnings)
POLYGON_API_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=

# Quote provider: blank = auto-pick first key; or pin polygon|finnhub|alphavantage|mock
MARKET_DATA_PROVIDER=

# Set to 1 to force synthetic bars (demo, no Polygon needed)
QUANTA_SYNTH_BARS=

# Economic-calendar currency filter and screener watchlist (optional)
CALENDAR_COUNTRIES=USD,EUR,GBP,JPY,CAD,AUD,CHF,NZD,CNY
SCREENER_SYMBOLS=AAPL,MSFT,NVDA,AMZN,META,GOOGL,TSLA,AMD,JPM,NFLX

# Host port published by docker compose (change if 8000 is already in use on the host).
# The container always listens on 8000 internally.
QUANTA_PORT=8000

# AI market summary (optional): if set, /api/summary uses Claude; otherwise a
# deterministic rule-based synthesis (both cite the underlying numbers).
ANTHROPIC_API_KEY=

# Intelligence-score category weights (optional JSON), e.g.
# QUANTA_SCORE_WEIGHTS={"options":0.2,"macro":0.1}
QUANTA_SCORE_WEIGHTS=
