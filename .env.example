# ─── Core ─────────────────────────────────────────────────────────────────────
# Use a long random string in production (e.g. `openssl rand -base64 48`)
JWT_SECRET=change-me-to-a-long-random-secret
# Comma-separated list of allowed browser origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Single-user mode: true removes the login/register requirement entirely.
# Only use on a private/self-hosted instance you control.
DISABLE_AUTH=false

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=quanta
POSTGRES_PASSWORD=quanta
POSTGRES_DB=quanta
# Used by the backend; compose wires host=postgres automatically
DATABASE_URL=postgres://quanta:quanta@postgres:5432/quanta?sslmode=disable

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Market data providers ──────────────────────────────────────────────────────
# Set at least one. Leave all blank to run in synthetic "mock" mode.
# Pin a provider with MARKET_DATA_PROVIDER, else the first configured key wins.
MARKET_DATA_PROVIDER=
POLYGON_API_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=

# Quote refresh interval for ingestion workers (Go duration syntax)
QUOTE_POLL_INTERVAL=5s

# ─── AI provider (used from Stage 4 onward; configure now to be ready) ──────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# ─── Server ─────────────────────────────────────────────────────────────────────
API_PORT=8080
LOG_LEVEL=info

# ─── Frontend (build/runtime) ───────────────────────────────────────────────────
# Browser-facing URLs to reach the backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080
